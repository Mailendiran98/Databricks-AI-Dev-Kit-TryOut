{
  "datasets": [
    {
      "name": "ds_total_count",
      "displayName": "Total Character Count",
      "queryLines": [
        "SELECT COUNT(*) as total_char FROM swapi_demo.gold.dim_characters"
      ]
    },
    {
      "name": "ds_avg_height",
      "displayName": "Average Height",
      "queryLines": [
        "SELECT ROUND(AVG(height_cm), 1) as avg_ht ",
        "FROM swapi_demo.gold.dim_characters ",
        "WHERE height_cm IS NOT NULL"
      ]
    },
    {
      "name": "ds_avg_mass",
      "displayName": "Average Mass",
      "queryLines": [
        "SELECT ROUND(AVG(mass_kg), 1) as avg_ms ",
        "FROM swapi_demo.gold.dim_characters ",
        "WHERE mass_kg IS NOT NULL"
      ]
    },
    {
      "name": "ds_height_cat_dist",
      "displayName": "Height Categories Distribution",
      "queryLines": [
        "SELECT height_category as cat, COUNT(*) as cnt ",
        "FROM swapi_demo.gold.dim_characters ",
        "WHERE height_category IS NOT NULL ",
        "GROUP BY height_category ",
        "ORDER BY cnt DESC"
      ]
    },
    {
      "name": "ds_mass_cat_dist",
      "displayName": "Mass Categories Distribution",
      "queryLines": [
        "SELECT mass_category as cat, COUNT(*) as cnt ",
        "FROM swapi_demo.gold.dim_characters ",
        "WHERE mass_category IS NOT NULL ",
        "GROUP BY mass_category ",
        "ORDER BY cnt DESC"
      ]
    },
    {
      "name": "ds_droid_split",
      "displayName": "Droid Distribution",
      "queryLines": [
        "SELECT CASE WHEN is_droid THEN 'Droid' ELSE 'Non-Droid' END as dtype, COUNT(*) as cnt ",
        "FROM swapi_demo.gold.dim_characters ",
        "GROUP BY is_droid"
      ]
    },
    {
      "name": "ds_top_tall",
      "displayName": "Top 10 Tallest Characters",
      "queryLines": [
        "SELECT character_name as name, height_cm as ht ",
        "FROM swapi_demo.gold.dim_characters ",
        "WHERE height_cm IS NOT NULL ",
        "ORDER BY height_cm DESC ",
        "LIMIT 10"
      ]
    },
    {
      "name": "ds_top_heavy",
      "displayName": "Top 10 Heaviest Characters",
      "queryLines": [
        "SELECT character_name as name, mass_kg as ms ",
        "FROM swapi_demo.gold.dim_characters ",
        "WHERE mass_kg IS NOT NULL ",
        "ORDER BY mass_kg DESC ",
        "LIMIT 10"
      ]
    },
    {
      "name": "ds_birth_timeline",
      "displayName": "Birth Year Distribution",
      "queryLines": [
        "SELECT CAST(birth_year_timeline AS INT) as yr, COUNT(*) as cnt ",
        "FROM swapi_demo.gold.dim_characters ",
        "WHERE birth_year_timeline IS NOT NULL ",
        "GROUP BY CAST(birth_year_timeline AS INT) ",
        "ORDER BY yr"
      ]
    }
  ],
